# Snippet pour Caddy global (caddy-global) — importé via /etc/caddy/projects/dog.caddy
# Généré par ./scripts/render-caddy-snippet.sh — ne pas éditer manuellement

${CADDY_DOMAIN} {
	handle /api/* {
		reverse_proxy dog-api:8080
	}
	handle /uploads/* {
		reverse_proxy dog-api:8080
	}
	handle {
		reverse_proxy dog-web:80
	}
	tls ${CADDY_ACME_EMAIL}
}
